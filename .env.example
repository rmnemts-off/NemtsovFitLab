# ─── Telegram ────────────────────────────────────────────────────────────────
# Токен бота (получить у @BotFather)
BOT_TOKEN=

# Полный HTTPS-URL для вебхука бота (домен твоего VPS + /webhook)
WEBHOOK_URL=https://yourdomain.com/webhook

# HTTPS-URL, по которому открывается Mini App (задаётся в @BotFather → Bot Settings → Menu Button)
MINI_APP_URL=https://yourdomain.com

# telegram_id тренера — для проверки прав в боте
TRAINER_TELEGRAM_ID=

# ─── База данных ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://fitlab:password@db:5432/fitlab

# Только для тестов (pytest)
TEST_DATABASE_URL=postgresql+asyncpg://fitlab:password@localhost:5432/fitlab_test

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Безопасность ────────────────────────────────────────────────────────────
# Случайная строка для подписи (openssl rand -hex 32)
SECRET_KEY=

# ─── Оплата — lava.top ───────────────────────────────────────────────────────
LAVA_TOP_API_KEY=
LAVA_TOP_SECRET_KEY=

# ─── PostgreSQL (для docker-compose) ─────────────────────────────────────────
POSTGRES_USER=fitlab
POSTGRES_PASSWORD=password
POSTGRES_DB=fitlab
